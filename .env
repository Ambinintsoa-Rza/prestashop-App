# Base URL of PrestaShop webservice (usually /api)
VITE_PS_BASE_URL=/ps-api

# Webservice key (do not commit your real key)
VITE_PS_WS_KEY=5YAFCHZNWP4LGTC45L1B4EP1BMJJAHBJ

# Optional: enable Vite proxy to avoid CORS during dev
# If set, use VITE_PS_BASE_URL=/ps-api
VITE_PS_PROXY_TARGET=http://localhost/prestashop/api

# Backoffice login (AdminLogin)
# If set, use VITE_PS_ADMIN_BASE_URL=/ps-admin
VITE_PS_ADMIN_BASE_URL=/ps-admin
VITE_PS_ADMIN_PROXY_TARGET=http://localhost/prestashop/admin_Ambinintsoa

# Optional: override order state IDs for the 3 allowed statuses
# VITE_ORDER_STATE_PAYMENT_FAILED_ID=8
# VITE_ORDER_STATE_PAYMENT_DONE_ID=2
# VITE_ORDER_STATE_CANCELED_ID=6
